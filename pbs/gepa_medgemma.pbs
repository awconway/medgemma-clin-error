#!/bin/bash
#PBS -N medgemma_gepa
#PBS -l select=1:ncpus=8:mem=64GB:ngpus=1:gpu_id=A100:gpu_sliced=False
#PBS -l walltime=08:00:00
#PBS -m abe
#PBS -j oe
#PBS -o logs/medgemma_gepa.$PBS_JOBID.log

set -euo pipefail

cd "$PBS_O_WORKDIR"
mkdir -p logs artifacts

# Optional cluster-specific environment setup:
# module purge
# module load cuda/12.4

source .venv/bin/activate

# Load environment variables from .env if present.
if [ -f .env ]; then
  set -a
  source .env
  set +a
fi

# Required:
# - HF_TOKEN must have access to google/medgemma-27b-it
# - OPENAI_API_KEY is recommended for stronger GEPA reflection (defaults to GPT-5.2 reflection if provided)
export HF_TOKEN="${HF_TOKEN:?Set HF_TOKEN for gated MedGemma access.}"
export MEDGEMMA_MODEL_NAME="${MEDGEMMA_MODEL_NAME:-sft_adapter}"
export MEDGEMMA_API_BASE="${MEDGEMMA_API_BASE:-http://127.0.0.1:8000/v1}"
export MEDGEMMA_API_KEY="${MEDGEMMA_API_KEY:-EMPTY}"

VLLM_HOST=127.0.0.1
VLLM_PORT=8000

python -m vllm.entrypoints.openai.api_server \
  --model google/medgemma-27b-it \
  --host "${VLLM_HOST}" \
  --port "${VLLM_PORT}" \
  --enable-lora \
  --lora-modules "sft_adapter=Vrda/medgemma-27b-clinical-error-sft" \
  --max-lora-rank 64 \
  --dtype bfloat16 \
  --max-model-len 8192 \
  --gpu-memory-utilization 0.85 \
  > "logs/vllm_${PBS_JOBID}.log" 2>&1 &
VLLM_PID=$!

cleanup() {
  kill "${VLLM_PID}" >/dev/null 2>&1 || true
}
trap cleanup EXIT

for _ in {1..120}; do
  if curl -fsS "http://${VLLM_HOST}:${VLLM_PORT}/v1/models" >/dev/null 2>&1; then
    break
  fi
  sleep 5
done

curl -fsS "http://${VLLM_HOST}:${VLLM_PORT}/v1/models" >/dev/null

python scripts/prepare_experiment_data.py
python scripts/run_gepa_experiment.py \
  --target medgemma \
  --auto medium \
  --num-threads 8 \
  --run-name "medgemma_${PBS_JOBID}"
