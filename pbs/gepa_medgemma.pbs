#!/bin/bash -l
#PBS -N medgemma_gepa
#PBS -l select=1:ncpus=8:mem=64GB:ngpus=1:gpu_id=A100:gpu_sliced=False
#PBS -l walltime=08:00:00
#PBS -m abe
#PBS -j oe
#PBS -o logs/medgemma_gepa.log

set -euo pipefail

cd "$PBS_O_WORKDIR"
mkdir -p logs artifacts
JOB_TAG="${PBS_JOBID:-manual}"
LOG_FILE="logs/medgemma_gepa.${JOB_TAG}.log"
exec >"${LOG_FILE}" 2>&1
echo "Logging to ${LOG_FILE}"

export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# Optional cluster-specific environment setup:
# module purge
# module load cuda/12.4
if [ -n "${CUDA_MODULE:-}" ]; then
  if ! command -v module >/dev/null 2>&1; then
    for MODULE_INIT in /etc/profile.d/modules.sh /usr/share/Modules/init/bash /usr/share/lmod/lmod/init/bash; do
      if [ -f "${MODULE_INIT}" ]; then
        # shellcheck disable=SC1090
        source "${MODULE_INIT}"
        break
      fi
    done
  fi
  if command -v module >/dev/null 2>&1; then
    module load "${CUDA_MODULE}"
  else
    echo "CUDA_MODULE is set (${CUDA_MODULE}) but module command is unavailable in this shell." >&2
  fi
fi

VLLM_ENV_DIR="${VLLM_ENV_DIR:-.vllm-env}"
if [ ! -f "${VLLM_ENV_DIR}/bin/activate" ]; then
  echo "Missing virtualenv at ${VLLM_ENV_DIR}. Set VLLM_ENV_DIR or create .vllm-env." >&2
  exit 1
fi
source "${VLLM_ENV_DIR}/bin/activate"

# Discover CUDA/Torch shared library dirs from this venv and add them to LD_LIBRARY_PATH.
VENV_CUDA_LIBS="$(
python - <<'PY'
import glob
import os
import site

candidates = []
roots = []
for root in site.getsitepackages():
    if root and os.path.isdir(root):
        roots.append(root)

for root in roots:
    patterns = [
        os.path.join(root, "nvidia", "**", "lib"),
        os.path.join(root, "nvidia", "**", "lib64"),
        os.path.join(root, "torch", "lib"),
    ]
    for pattern in patterns:
        for d in glob.glob(pattern, recursive=True):
            if os.path.isdir(d):
                candidates.append(os.path.realpath(d))

seen = set()
ordered = []
for d in candidates:
    if d not in seen:
        seen.add(d)
        ordered.append(d)

print(":".join(ordered))
PY
)"

SYSTEM_CUDA_LIBS=()
for d in /usr/local/cuda/lib64 /usr/local/cuda-12/lib64 /usr/local/cuda-12.4/lib64; do
  if [ -d "$d" ]; then
    SYSTEM_CUDA_LIBS+=("$d")
  fi
done
SYSTEM_CUDA_LIBS_JOINED="$(IFS=:; echo "${SYSTEM_CUDA_LIBS[*]}")"

if [ -n "${VENV_CUDA_LIBS}" ] && [ -n "${SYSTEM_CUDA_LIBS_JOINED}" ]; then
  export LD_LIBRARY_PATH="${VENV_CUDA_LIBS}:${SYSTEM_CUDA_LIBS_JOINED}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
elif [ -n "${VENV_CUDA_LIBS}" ]; then
  export LD_LIBRARY_PATH="${VENV_CUDA_LIBS}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
elif [ -n "${SYSTEM_CUDA_LIBS_JOINED}" ]; then
  export LD_LIBRARY_PATH="${SYSTEM_CUDA_LIBS_JOINED}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi

if ! python - <<'PY'
import ctypes
ctypes.CDLL("libcudart.so.12")
PY
then
  echo "Missing CUDA runtime (libcudart.so.12). Tried venv/system CUDA library paths; if needed set CUDA_MODULE or LD_LIBRARY_PATH manually." >&2
  exit 1
fi

# Load environment variables from .env if present.
if [ -f .env ]; then
  set -a
  source .env
  set +a
fi

# Required:
# - HF_TOKEN must have access to google/medgemma-27b-it
# - OPENAI_API_KEY is recommended for stronger GEPA reflection (defaults to GPT-5.2 reflection if provided)
export HF_TOKEN="${HF_TOKEN:?Set HF_TOKEN for gated MedGemma access.}"
export HUGGING_FACE_HUB_TOKEN="${HUGGING_FACE_HUB_TOKEN:-$HF_TOKEN}"
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"
export HUGGINGFACE_HUB_CACHE="${HUGGINGFACE_HUB_CACHE:-$HF_HOME/hub}"
export MEDGEMMA_MODEL_NAME="${MEDGEMMA_MODEL_NAME:-sft_adapter}"
export MEDGEMMA_API_KEY="${MEDGEMMA_API_KEY:-EMPTY}"

VLLM_HOST=127.0.0.1

# Pick a random free local port for this job's vLLM server.
if command -v nc >/dev/null 2>&1; then
  while :; do
    VLLM_PORT=$((20000 + RANDOM % 20000))
    if ! nc -z "${VLLM_HOST}" "${VLLM_PORT}" 2>/dev/null; then
      break
    fi
  done
else
  VLLM_PORT="$(
    python - <<'PY'
import random
import socket

for _ in range(2000):
    port = random.randint(20000, 39999)
    with socket.socket() as s:
        try:
            s.bind(("127.0.0.1", port))
        except OSError:
            continue
        print(port)
        break
else:
    print(8000)
PY
  )"
fi

export MEDGEMMA_API_BASE="http://${VLLM_HOST}:${VLLM_PORT}/v1"
echo "Using vLLM endpoint: ${MEDGEMMA_API_BASE}"

VLLM_LOG="logs/vllm_${PBS_JOBID}.log"
python -m vllm.entrypoints.openai.api_server \
  --model google/medgemma-27b-it \
  --host "${VLLM_HOST}" \
  --port "${VLLM_PORT}" \
  --enable-lora \
  --lora-modules "sft_adapter=Vrda/medgemma-27b-clinical-error-sft" \
  --max-lora-rank 64 \
  --dtype bfloat16 \
  --max-model-len 8192 \
  --gpu-memory-utilization 0.85 \
  > "${VLLM_LOG}" 2>&1 &
VLLM_PID=$!

cleanup() {
  kill "${VLLM_PID}" >/dev/null 2>&1 || true
}
trap cleanup EXIT

READY=0
for _ in {1..120}; do
  if ! kill -0 "${VLLM_PID}" >/dev/null 2>&1; then
    echo "vLLM process exited before startup completed. Log tail:" >&2
    tail -n 200 "${VLLM_LOG}" >&2 || true
    exit 1
  fi
  if curl -fsS "http://${VLLM_HOST}:${VLLM_PORT}/v1/models" >/dev/null 2>&1; then
    READY=1
    break
  fi
  sleep 5
done

if [ "${READY}" -ne 1 ]; then
  echo "Timed out waiting for vLLM endpoint ${MEDGEMMA_API_BASE}." >&2
  tail -n 200 "${VLLM_LOG}" >&2 || true
  exit 1
fi

python scripts/prepare_experiment_data.py
python scripts/run_gepa_experiment.py \
  --target medgemma \
  --auto medium \
  --num-threads 8 \
  --run-name "medgemma_${PBS_JOBID}"
